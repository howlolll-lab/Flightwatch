   info:{hc:{k:'手提行李',v:'依選擇航班',c:''},ck:{k:'托運行李',v:'依選擇航班',c:''},ch:{k:'改期費用',v:'依選擇航班',c:''},rf:{k:'退票政策',v:'依選擇航班',c:''},bf:{k:'訂位方式',v:'ITA 僅查詢，需到航空公司官網購票',c:'warn'},pm:{k:'付款方式',v:'不適用（僅查詢工具）',c:''},ml:{k:'里程累積',v:'依最終選擇航班',c:''},pv:{k:'無痕建議',v:'開無痕視窗使用',c:'warn'},nt:{k:'備註',v:'Google 旗下工具，可查最原始票價代碼，適合研究票種差異的進階旅客',c:''}}}
];

/* 單程基礎票價 NT$ */
const BASE={google:7200,skyscanner:6800,kayak:7000,ita:6700,cal:8500,eva:8200,starlux:9000};

function ei(s){return(s.split('—')[0]||s).trim().toUpperCase();}
function calcP(id,isRound){
  const b=BASE[id];
  return isRound ? Math.round(b*1.85/100)*100 : b;
}

function setTrip(t){
  tripType=t;
  ['rt','ow','mc'].forEach(x=>document.getElementById('btn-'+x).classList.remove('active'));
  document.getElementById('btn-'+{round:'rt',one:'ow',multi:'mc'}[t]).classList.add('active');
  document.getElementById('ret-grp').style.display=t==='one'?'none':'';
  if(curS) renderCh();
}

function swapAirports(){
  const a=document.getElementById('origin'),b=document.getElementById('dest');
  [a.value,b.value]=[b.value,a.value];
  toast('出發 ⇄ 目的地已交換');
}

function doSearch(){
  const origin=document.getElementById('origin').value.trim()||'TPE — 台北桃園';
  const dest=document.getElementById('dest').value.trim()||'UKB — 神戶';
  const dep=document.getElementById('dep-date').value||'2026-06-05';
  const ret=document.getElementById('ret-date').value||'2026-06-08';
  const pax=parseInt(document.getElementById('pax').value);
  const cabin=document.getElementById('cabin').options[document.getElementById('cabin').selectedIndex].text;
  curS={origin,dest,dep,ret,pax,cabin,type:tripType};

  const isR=tripType==='round';
  const prices=CHS.map(c=>calcP(c.id,isR)*pax);
  const minP=Math.min(...prices);
  const avgP=Math.round(prices.reduce((a,b)=>a+b,0)/prices.length);
  const dl=Math.ceil((new Date(dep)-new Date())/86400000);

  document.getElementById('sv-low').textContent='NT$'+minP.toLocaleString();
  document.getElementById('sv-avg').textContent='NT$'+avgP.toLocaleString();
  document.getElementById('sv-days').textContent=dl>0?dl+' 天':'已過期';
  document.getElementById('lbl-low').textContent=isR?'來回最低':'單程最低';
  document.getElementById('lbl-avg').textContent=isR?'來回均價':'單程均價';
  document.getElementById('res-sec').style.display='block';

  renderCh();
  saveH(curS,minP);
  renderH();
  checkA(minP);
  toast('找到 '+CHS.length+' 個渠道報價');
  setTimeout(()=>document.getElementById('res-sec').scrollIntoView({behavior:'smooth',block:'start'}),100);
}

function renderCh(){
  if(!curS) return;
  const isR=tripType==='round';
  const pax=parseInt(document.getElementById('pax').value)||1;
  const sortBy=document.getElementById('sortby').value;
  const chs=[...CHS].sort((a,b)=>sortBy==='price'?calcP(a.id,isR)*pax-calcP(b.id,isR)*pax:b.rec-a.rec);
  const minP=Math.min(...chs.map(c=>calcP(c.id,isR)*pax));

  document.getElementById('ch-list').innerHTML=chs.map(ch=>{
    const p=calcP(ch.id,isR)*pax;
    const isBest=p===minP;
    const priceLabel=isR?'來回':'單程';
    const o=ei(curS.origin), d=ei(curS.dest);
    const url=ch.url(o,d,curS.dep,curS.ret,tripType);
    const isOfficialSite=['cal','eva','starlux'].includes(ch.id);
    const btnLabel=isOfficialSite?'官網<br>直購':'搜尋<br>此票';
    const discCount=(ch.discounts||[]).length;
    return `<div class="chcard${isBest?' best':''}">
      <div class="ch-main">
        <div class="ch-info" onclick="openModal('${ch.id}')">
          <div class="ctop">
            <div class="cname">
              <div style="width:9px;height:9px;border-radius:50%;background:${ch.color};flex-shrink:0"></div>
              ${ch.name}${isBest?'<span class="pill pg">最低價</span>':''}
            </div>
            <div class="pblock">
              <div class="cprice${isBest?' low':''}">NT$${p.toLocaleString()}</div>
              <div class="cpnote">${priceLabel}・${pax} 人合計</div>
            </div>
          </div>
          <div class="cbot">
            <div class="cdesc">${ch.desc}</div>
            <div class="cbadges">
              ${ch.badges.map(b=>`<span class="pill pgr">${b}</span>`).join('')}
              ${discCount?`<span class="pill" style="background:#fef9c3;color:#854d0e;border:1px solid #fde047">折扣 ${discCount} 項</span>`:''}
              <span class="ahint"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>行李/折扣</span>
            </div>
          </div>
        </div>
        <div class="ch-divider"></div>
        <div style="display:flex;flex-direction:column;flex-shrink:0;">
          <button class="ch-gobtn" style="flex:1;border-bottom:0.5px solid rgba(255,255,255,0.2);" onclick="event.stopPropagation();window.open('${url.replace(/'/g,"\\'")}','_blank','noopener,noreferrer')" title="開新視窗前往購票（非無痕）">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            <span style="font-size:9px;font-weight:700;text-align:center;line-height:1.4;">${btnLabel}</span>
          </button>
          <button class="ch-copybtn" onclick="event.stopPropagation();copyLink('${url.replace(/'/g,"\\'")}','${ch.name}')" title="複製連結 → 貼到無痕視窗（推薦）">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span style="font-size:9px;font-weight:600;line-height:1.3;">無痕<br>連結</span>
          </button>
        </div>
      </div>
    </div>`;
  }).join('');
}

/* MODAL */
function openModal(id){
  const ch=CHS.find(c=>c.id===id);
  if(!ch||!curS) return;
  const isR=tripType==='round';
  const pax=parseInt(document.getElementById('pax').value)||1;
  const pp=calcP(id,isR);
  const total=pp*pax;
  const url=ch.url(ei(curS.origin),ei(curS.dest),curS.dep,curS.ret,tripType);
  const o=curS.origin.split('—')[0].trim(), d=curS.dest.split('—')[0].trim();
  const priceLabel=isR?'來回票價 / 人':'單程票價 / 人';

  document.getElementById('mtitle').textContent=ch.name+' — 行李、折扣與退改票';
  const secs=[
    {title:'行李規定',keys:['hc','ck']},
    {title:'改票 / 退票',keys:['ch','rf']},
    {title:'付款與里程',keys:['bf','pm','ml']},
    {title:'無痕建議與備註',keys:['pv','nt']}
  ];
  const discHTML=(ch.discounts||[]).length ? `
    <div class="isec">
      <div class="isechtitle" style="color:#854d0e">折扣、優惠券與省錢技巧</div>
      ${(ch.discounts||[]).map(d=>`
        <div class="irow" style="align-items:flex-start">
          <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;min-width:80px">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="ikey" style="color:#92400e;font-weight:500">${d.label}</span>
          </div>
          <div class="ival" style="color:#78350f;font-weight:400;text-align:right">${d.desc}</div>
        </div>`).join('')}
    </div>` : '';
  document.getElementById('mcontent').innerHTML=`
    <div class="phero">
      <div class="phroute">${o} → ${d}　${isR?'來回':'單程'}　${curS.dep}${isR?' / '+curS.ret:''}</div>
      <div class="phgrid">
        <div><div class="phlbl">${priceLabel}</div><div class="phval">NT$${pp.toLocaleString()}</div></div>
        ${pax>1?`<div><div class="phlbl">人數</div><div class="phval" style="color:var(--text2)">× ${pax} 人</div></div>`:''}
      </div>
      ${pax>1?`<div class="phtotal"><span class="phtlbl">總合計金額</span><span class="phtval">NT$${total.toLocaleString()}</span></div>`:''}
    </div>
    ${discHTML}
    ${secs.map(s=>`
    <div class="isec">
      <div class="isechtitle">${s.title}</div>
      ${s.keys.map(k=>`<div class="irow"><div class="ikey">${ch.info[k].k}</div><div class="ival ${ch.info[k].c}">${ch.info[k].v}</div></div>`).join('')}
    </div>`).join('')}
    <button class="buybtn" onclick="window.open('${url.replace(/'/g,"\\'")}','_blank','noopener,noreferrer')">前往 ${ch.name} — 直接搜尋此航班 ↗</button>
    <div class="pvnote">建議在無痕視窗中開啟，避免被追蹤後票價調漲</div>
  `;
  document.getElementById('moverlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(e){
  if(e&&e.target.id!=='moverlay') return;
  document.getElementById('moverlay').classList.remove('open');
  document.body.style.overflow='';
}

/* HISTORY */
function gH(){try{return JSON.parse(localStorage.getItem(HK)||'[]');}catch{return[];}}
function saveH(s,p){
  const a=gH();
  a.unshift({route:`${ei(s.origin)} → ${ei(s.dest)}`,type:s.type==='round'?'來回':'單程',dep:s.dep,ret:s.ret||'',price:'NT$'+p.toLocaleString(),ts:new Date().toLocaleString('zh-TW',{hour12:false}).slice(0,16)});
  if(a.length>30)a.pop();
  try{localStorage.setItem(HK,JSON.stringify(a));}catch{}
}
function renderH(){
  const a=gH();
  const cols=['#2563eb','#059669','#d97706','#7c3aed','#dc2626'];
  if(!a.length){document.getElementById('hbody').innerHTML='<div class="empty">尚無搜尋紀錄<br>點擊「搜尋並比較」開始追蹤</div>';return;}
  document.getElementById('hbody').innerHTML=a.map((h,i)=>`
    <div class="hitem">
      <div class="hdot" style="background:${cols[i%5]}"></div>
      <div class="hinfo"><div class="hroute">${h.route} <span style="font-size:11px;color:var(--text3)">${h.type}</span></div>
      <div class="hmeta">${h.dep}${h.ret?' / '+h.ret:''} · ${h.ts}</div></div>
      <div class="hprice">${h.price}</div>
      <button class="hact" onclick="doSearch()">重搜</button>
    </div>`).join('')+
    `<div style="padding:10px 0"><button onclick="clrH()" style="font-size:12px;background:none;border:1px solid var(--border);border-radius:8px;color:var(--text3);padding:5px 12px;cursor:pointer">清除全部</button></div>`;
}
function clrH(){try{localStorage.removeItem(HK);}catch{}renderH();toast('紀錄已清除');}

/* ALERTS */
function gA(){try{return JSON.parse(localStorage.getItem(AK)||'[]');}catch{return[];}}
function fillA(p){document.getElementById('av').value=p;}
function addAlert(){
  const v=parseInt(document.getElementById('av').value);
  if(!v||v<1000){toast('請輸入有效金額');return;}
  const a=gA();
  a.unshift({price:v,route:curS?`${ei(curS.origin)} → ${ei(curS.dest)}`:'TPE → UKB',created:new Date().toLocaleString('zh-TW',{hour12:false}).slice(0,16),active:true});
  try{localStorage.setItem(AK,JSON.stringify(a));}catch{}
  document.getElementById('av').value='';
  renderA();toast('已設定：來回低於 NT$'+v.toLocaleString()+' 時通知');
  addN('alert','已建立提醒：來回票價低於 NT$'+v.toLocaleString()+' 時通知你',true);
}
function rmA(i){const a=gA();a.splice(i,1);try{localStorage.setItem(AK,JSON.stringify(a));}catch{}renderA();}
function checkA(p){gA().filter(a=>a.active&&p<=a.price).forEach(a=>{addN('drop','價格提醒觸發！票價 NT$'+p.toLocaleString()+' 已低於目標 NT$'+a.price.toLocaleString(),false);toast('價格提醒！NT$'+p.toLocaleString()+' 已達目標');});}
function renderA(){
  const a=gA();
  if(!a.length){document.getElementById('abody').innerHTML='<div class="empty">尚無提醒設定</div>';return;}
  document.getElementById('abody').innerHTML=a.map((x,i)=>`
    <div class="aitem">
      <div class="asta" style="background:${x.active?'var(--green)':'var(--text3)'}"></div>
      <div class="ainfo"><div class="atgt">來回低於 NT$${x.price.toLocaleString()}</div><div class="adate">${x.route} · ${x.created}</div></div>
      <button class="adel" onclick="rmA(${i})">✕</button>
    </div>`).join('');
}

/* TREND */
const TD=[{w:'10週',p:22400},{w:'9週',p:21200},{w:'8週',p:19800},{w:'7週',p:18400},{w:'6週',p:16800},{w:'5週',p:16200},{w:'4週',p:16000},{w:'3週',p:17200},{w:'2週',p:19000},{w:'1週',p:21600},{w:'出發',p:24500}];
function renderTrend(){
  const mx=Math.max(...TD.map(d=>d.p));
  document.getElementById('tbars').innerHTML=TD.map(d=>{
    const pct=Math.round(d.p/mx*100);
    const c=d.p<17000?'var(--green)':d.p<20000?'var(--amber)':'var(--red)';
    return`<div class="bwrap" title="NT$${d.p.toLocaleString()}"><div class="bar" style="height:${pct}%;background:${c}"></div><div class="blbl">${d.w}</div></div>`;
  }).join('');
}

/* NOTIF */
function gN(){try{return JSON.parse(localStorage.getItem(NK)||'[]');}catch{return[];}}
function addN(type,msg,read=false){
  const a=gN();a.unshift({type,msg,ts:new Date().toLocaleString('zh-TW',{hour12:false}).slice(0,16),read});
  if(a.length>20)a.pop();try{localStorage.setItem(NK,JSON.stringify(a));}catch{}renderN();
}
function renderN(){
  const a=gN();const u=a.filter(n=>!n.read).length;
  document.getElementById('nbadge').style.display=u?'block':'none';
  const icons={alert:'🔔',drop:'📉',search:'🔍'};
  if(!a.length){document.getElementById('nlist').innerHTML='<div class="empty">目前沒有通知</div>';return;}
  document.getElementById('nlist').innerHTML=a.map(n=>`
    <div class="nitem${n.read?'':' unread'}">
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px"><span>${icons[n.type]||'ℹ️'}</span><span class="ntype">${n.type==='drop'?'價格提醒':n.type==='alert'?'已設定提醒':'通知'}</span></div>
      <div class="nmsg">${n.msg}</div><div class="ntime">${n.ts}</div>
    </div>`).join('');
}
function openNotif(){
  document.getElementById('nopanel').classList.add('open');document.getElementById('nobg').classList.add('open');
  const a=gN().map(n=>({...n,read:true}));try{localStorage.setItem(NK,JSON.stringify(a));}catch{}setTimeout(renderN,300);
}
function closeNotif(){document.getElementById('nopanel').classList.remove('open');document.getElementById('nobg').classList.remove('open');}

/* TABS */
function switchTab(id){
  document.querySelectorAll('.tabbtn').forEach((b,i)=>b.classList.toggle('active',['history','alerts','trend'][i]===id));
  document.querySelectorAll('.tabcon').forEach(c=>c.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
}

/* MOBILE NAV */
function mNav(p){
  document.querySelectorAll('.navitem').forEach(n=>n.classList.remove('active'));
  document.getElementById('nav-'+p).classList.add('active');
  const ps=document.getElementById('pg-search'),ha=document.getElementById('pg-ha');
  if(p==='search'){ps.style.display='';ha.style.display='';}
  else{
    ps.style.display='none';ha.style.display='';
    document.querySelectorAll('.tabcon').forEach(c=>{c.classList.remove('active','ma');});
    const map={history:'tab-history',alerts:'tab-alerts',trend:'tab-trend'};
    if(map[p]){const el=document.getElementById(map[p]);el.classList.add('active','ma');}
    switchTab(p);
  }
  window.scrollTo(0,0);
}

/* PRIVACY */
function togglePv(){
  const e=document.getElementById('pvsteps'),c=document.getElementById('pvchev');
  e.classList.toggle('open');c.style.transform=e.classList.contains('open')?'rotate(180deg)':'';
}

/* TOAST */
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2200);}

/* COPY LINK */
function copyLink(url,name){
  navigator.clipboard.writeText(url).then(()=>{
    toast('已複製 '+name+' 連結 — 請貼到無痕視窗網址列');
  }).catch(()=>{
    prompt('請複製以下連結，貼到無痕視窗網址列：',url);
  });
}

/* INIT */
renderH();renderA();renderTrend();renderN();
addN('search','歡迎使用 FlightWatch！搜尋 TPE → UKB 開始追蹤來回票價。',false);
</script>
