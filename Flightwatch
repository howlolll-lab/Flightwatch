<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#f4f5f7">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>FlightWatch — 機票追蹤</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4f5f7;--bg2:#ffffff;--bg3:#f0f1f4;--bg4:#e8eaef;
  --accent:#2563eb;--green:#059669;--amber:#d97706;--red:#dc2626;--purple:#7c3aed;
  --text:#111827;--text2:#4b5563;--text3:#9ca3af;
  --border:#e5e7eb;--border2:#d1d5db;
  --shadow:0 1px 4px rgba(0,0,0,.08);--shadow-lg:0 4px 20px rgba(0,0,0,.12);
  --r:12px;--r-lg:16px;
  --mono:'Space Mono',monospace;--body:'Noto Sans TC',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:14px;min-height:100vh;overflow-x:hidden;}
.app{max-width:860px;margin:0 auto;padding:0 16px 100px;}

.header{display:flex;align-items:center;justify-content:space-between;padding:18px 0 14px;border-bottom:1px solid var(--border);margin-bottom:20px;}
.logo{font-family:var(--mono);font-size:14px;font-weight:700;letter-spacing:.08em;display:flex;align-items:center;gap:8px;}
.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.hbtns{display:flex;gap:8px;}
.ibtn{width:36px;height:36px;border-radius:10px;border:1px solid var(--border2);background:var(--bg2);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;position:relative;}
.ibtn:hover{border-color:var(--accent);color:var(--accent);}
.bdot{position:absolute;top:7px;right:7px;width:7px;height:7px;border-radius:50%;background:var(--red);border:1.5px solid var(--bg2);display:none;}

.stitle{font-family:var(--mono);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;}

.scard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;margin-bottom:14px;box-shadow:var(--shadow);}
.ttog{display:flex;gap:0;margin-bottom:16px;background:var(--bg3);border-radius:8px;padding:3px;}
.tbtn{flex:1;padding:7px 0;font-size:12px;font-family:var(--body);font-weight:500;border:none;border-radius:6px;background:transparent;color:var(--text2);cursor:pointer;transition:all .2s;}
.tbtn.active{background:var(--accent);color:#fff;box-shadow:0 2px 6px rgba(37,99,235,.3);}

.igrid{display:grid;gap:10px;}
.igrp{display:flex;flex-direction:column;gap:5px;}
.ilbl{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);font-family:var(--mono);}
.iwrap{position:relative;}
.iwrap svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);opacity:.35;pointer-events:none;}
.fi{width:100%;padding:10px 11px 10px 34px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-family:var(--body);font-size:14px;transition:border-color .15s;outline:none;-webkit-appearance:none;}
.fi:focus{border-color:var(--accent);background:#fff;}
.fi::placeholder{color:var(--text3);}
input[type="date"].fi{color-scheme:light;}
.fi0{padding-left:11px;}
.arow{display:grid;grid-template-columns:1fr 36px 1fr;gap:6px;align-items:end;}
.swpbtn{width:36px;height:36px;border-radius:50%;background:var(--bg3);border:1px solid var(--border2);color:var(--text2);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;}
.swpbtn:hover{border-color:var(--accent);color:var(--accent);transform:rotate(180deg);}
.drow,.erow{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.sbtn{width:100%;margin-top:14px;padding:12px;border:none;border-radius:var(--r);background:var(--accent);color:#fff;font-size:14px;font-weight:700;font-family:var(--body);cursor:pointer;transition:all .2s;}
.sbtn:hover{background:#1d4ed8;}
.sbtn:active{transform:scale(.98);}

.pvbanner{display:flex;align-items:center;gap:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:var(--r);padding:10px 14px;margin-bottom:14px;font-size:12px;color:var(--green);cursor:pointer;}
.pvsteps{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:14px 18px;margin-bottom:14px;display:none;box-shadow:var(--shadow);}
.pvsteps.open{display:block;}
.sti{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.sti:last-child{border-bottom:none;}
.snum{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:1px solid var(--border2);font-family:var(--mono);font-size:10px;color:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.stit{font-size:13px;font-weight:500;margin-bottom:2px;}
.sdesc{font-size:12px;color:var(--text2);line-height:1.5;}
.vtip{background:#fffbeb;border:1px solid #fde68a;border-radius:var(--r);padding:10px 12px;margin-top:8px;font-size:12px;color:var(--amber);line-height:1.5;}

.strow{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px;}
.stpill{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;box-shadow:var(--shadow);}
.stlbl{font-size:10px;color:var(--text3);letter-spacing:.05em;margin-bottom:3px;font-family:var(--mono);}
.stval{font-size:17px;font-weight:700;font-family:var(--mono);}

.rhead{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.ssel{font-size:12px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:5px 10px;color:var(--text2);cursor:pointer;outline:none;-webkit-appearance:none;}

.chcard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);margin-bottom:9px;overflow:hidden;box-shadow:var(--shadow);transition:box-shadow .2s;}
.chcard:hover{box-shadow:var(--shadow-lg);}
.chcard.best{border-color:#bbf7d0;background:#f0fdf4;}
.ch-main{display:flex;align-items:stretch;gap:0;}
.ch-info{flex:1;padding:14px 16px;cursor:pointer;transition:background .15s;min-width:0;}
.ch-info:hover{background:rgba(37,99,235,.04);}
.chcard.best .ch-info:hover{background:rgba(5,150,105,.06);}
.ch-gobtn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;padding:0 12px;background:var(--accent);color:#fff;cursor:pointer;border:none;font-family:var(--body);transition:background .15s;min-width:58px;flex-shrink:0;}
.ch-gobtn:hover{background:#1d4ed8;}
.chcard.best .ch-gobtn{background:var(--green);}
.chcard.best .ch-gobtn:hover{background:#047857;}
.ch-copybtn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;padding:0 12px;background:#f1f5f9;color:#475569;cursor:pointer;border:none;font-family:var(--body);transition:background .15s;min-width:58px;flex-shrink:0;}
.ch-copybtn:hover{background:#e2e8f0;}
.ch-divider{width:1px;background:var(--border);flex-shrink:0;}
.ctop{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.cname{font-size:14px;font-weight:500;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.pblock{text-align:right;}
.cprice{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--text);line-height:1.2;}
.cprice.low{color:var(--green);}
.cpnote{font-size:10px;color:var(--text3);margin-top:2px;font-family:var(--mono);}
.cbot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;}
.cdesc{font-size:12px;color:var(--text2);}
.cbadges{display:flex;gap:5px;flex-wrap:wrap;align-items:center;}
.ahint{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:3px;}

.pill{font-size:10px;padding:2px 8px;border-radius:20px;font-weight:500;white-space:nowrap;}
.pg{background:#dcfce7;color:#166534;border:1px solid #bbf7d0;}
.pa{background:#fef3c7;color:#92400e;border:1px solid #fde68a;}
.pb{background:#dbeafe;color:#1e40af;border:1px solid #bfdbfe;}
.pp{background:#ede9fe;color:#5b21b6;border:1px solid #ddd6fe;}
.pgr{background:#f3f4f6;color:#374151;border:1px solid #e5e7eb;}
.pr{background:#fee2e2;color:#991b1b;border:1px solid #fecaca;}

/* MODAL */
.moverlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;backdrop-filter:blur(2px);}
.moverlay.open{display:flex;align-items:flex-end;justify-content:center;}
@media(min-width:600px){.moverlay.open{align-items:center;}}
.modal{background:var(--bg2);border-radius:20px 20px 0 0;width:100%;max-width:540px;max-height:90vh;overflow-y:auto;box-shadow:0 -4px 30px rgba(0,0,0,.15);}
@media(min-width:600px){.modal{border-radius:20px;}}
.mhandle{width:36px;height:4px;border-radius:2px;background:var(--border2);margin:12px auto 0;}
.mhdr{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 10px;}
.mtitle{font-size:16px;font-weight:700;}
.mclose{width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:var(--text2);}
.mclose:hover{background:var(--bg3);}
.mbody{padding:0 20px 24px;}

.phero{background:var(--bg3);border-radius:var(--r);padding:14px 16px;margin-bottom:16px;}
.phroute{font-size:12px;color:var(--text2);margin-bottom:8px;}
.phgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.phlbl{font-size:10px;color:var(--text3);font-family:var(--mono);letter-spacing:.06em;margin-bottom:2px;}
.phval{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--green);}
.phtotal{margin-top:10px;padding-top:10px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:baseline;}
.phtlbl{font-size:12px;color:var(--text2);}
.phtval{font-family:var(--mono);font-size:16px;font-weight:700;color:var(--accent);}

.isec{margin-bottom:14px;}
.isechtitle{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);font-family:var(--mono);margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border);}
.irow{display:flex;align-items:flex-start;justify-content:space-between;padding:7px 0;border-bottom:1px dashed var(--border);gap:12px;}
.irow:last-child{border-bottom:none;}
.ikey{font-size:13px;color:var(--text2);flex-shrink:0;min-width:80px;}
.ival{font-size:13px;font-weight:500;text-align:right;line-height:1.4;}
.ival.good{color:var(--green);}
.ival.warn{color:var(--amber);}
.ival.bad{color:var(--red);}

.buybtn{width:100%;padding:13px;border:none;border-radius:var(--r);background:var(--accent);color:#fff;font-size:15px;font-weight:700;font-family:var(--body);cursor:pointer;transition:all .2s;margin-bottom:8px;}
.buybtn:hover{background:#1d4ed8;}
.buybtn:active{transform:scale(.98);}
.pvnote{font-size:11px;color:var(--text3);text-align:center;line-height:1.5;}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:16px;}
.tabbtn{padding:9px 16px;font-size:13px;font-weight:500;background:transparent;border:none;border-bottom:2px solid transparent;color:var(--text2);cursor:pointer;transition:all .15s;margin-bottom:-1px;font-family:var(--body);}
.tabbtn.active{color:var(--accent);border-bottom-color:var(--accent);}
.tabcon{display:none;}.tabcon.active{display:block;}

.hitem{display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--border);}
.hitem:last-child{border-bottom:none;}
.hdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.hinfo{flex:1;min-width:0;}
.hroute{font-size:13px;font-weight:500;}
.hmeta{font-size:11px;color:var(--text3);margin-top:2px;font-family:var(--mono);}
.hprice{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--green);white-space:nowrap;}
.hact{font-size:11px;padding:4px 8px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;}
.hact:hover{border-color:var(--border2);}
.empty{text-align:center;padding:36px 20px;color:var(--text3);font-size:13px;line-height:1.7;}

.apresets{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.apc{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:10px 12px;cursor:pointer;transition:all .2s;}
.apc:hover{border-color:var(--accent);}
.aplbl{font-size:11px;color:var(--text2);margin-bottom:3px;}
.apprice{font-family:var(--mono);font-size:16px;font-weight:700;}
.apnote{font-size:11px;color:var(--text3);margin-top:2px;}
.aform{display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap;}
.ainput{flex:1;min-width:100px;padding:9px 11px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);font-family:var(--mono);font-size:14px;outline:none;transition:border-color .15s;}
.ainput:focus{border-color:var(--accent);background:#fff;}
.aaddbtn{padding:9px 16px;border:none;border-radius:var(--r);background:var(--accent);color:#fff;font-weight:700;font-family:var(--body);font-size:13px;cursor:pointer;white-space:nowrap;}
.aaddbtn:hover{background:#1d4ed8;}
.aitem{display:flex;align-items:center;gap:10px;padding:11px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);margin-bottom:7px;}
.asta{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.ainfo{flex:1;}
.atgt{font-family:var(--mono);font-size:14px;font-weight:700;}
.adate{font-size:11px;color:var(--text3);margin-top:2px;}
.adel{width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text3);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;}
.adel:hover{border-color:var(--red);color:var(--red);}

.cbars{display:flex;align-items:flex-end;gap:4px;height:90px;margin-bottom:6px;}
.bwrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end;}
.bar{width:100%;border-radius:4px 4px 0 0;min-height:4px;transition:height .5s cubic-bezier(.4,0,.2,1);}
.blbl{font-size:9px;color:var(--text3);font-family:var(--mono);white-space:nowrap;}
.cax{display:flex;justify-content:space-between;margin-top:4px;}
.axv{font-size:10px;color:var(--text3);font-family:var(--mono);}

.nobg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.25);z-index:99;backdrop-filter:blur(2px);}
.nobg.open{display:block;}
.nopanel{position:fixed;top:0;right:0;bottom:0;width:min(320px,100vw);background:var(--bg2);border-left:1px solid var(--border2);z-index:100;padding:20px;overflow-y:auto;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);box-shadow:-4px 0 20px rgba(0,0,0,.08);}
.nopanel.open{transform:translateX(0);}
.nohdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.notit{font-size:15px;font-weight:700;}
.noclose{width:30px;height:30px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;}
.nitem{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:11px;margin-bottom:7px;}
.nitem.unread{border-color:#bfdbfe;background:#eff6ff;}
.ntype{font-size:11px;font-weight:500;color:var(--text2);}
.nmsg{font-size:13px;line-height:1.5;margin-top:3px;}
.ntime{font-size:11px;color:var(--text3);margin-top:4px;font-family:var(--mono);}

.bnav{display:none;position:fixed;bottom:0;left:0;right:0;background:rgba(255,255,255,.96);border-top:1px solid var(--border);backdrop-filter:blur(12px);padding:6px 0 max(6px,env(safe-area-inset-bottom));z-index:50;}
.navitems{display:flex;justify-content:space-around;}
.navitem{display:flex;flex-direction:column;align-items:center;gap:3px;padding:5px 14px;cursor:pointer;background:none;border:none;color:var(--text3);font-size:10px;font-family:var(--body);transition:color .15s;}
.navitem.active{color:var(--accent);}

.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(10px);background:var(--text);border-radius:10px;padding:9px 18px;font-size:13px;color:#fff;opacity:0;transition:all .3s;z-index:300;white-space:nowrap;box-shadow:var(--shadow-lg);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

@media(min-width:600px){
  .igrid{grid-template-columns:1fr 1fr;}
  .arow,.drow,.erow{grid-column:1/-1;}
  .bnav{display:none!important;}
  .app{padding:0 24px 40px;}
  .header{padding:26px 0 18px;}
}
@media(max-width:599px){
  .bnav{display:block;}
  .tabs{display:none;}
  .tabcon{display:none!important;}
  .tabcon.ma{display:block!important;}
  .stval{font-size:14px;}
  .cprice{font-size:15px;}
  .phval{font-size:18px;}
}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="logo"><div class="logo-dot"></div>FLIGHTWATCH</div>
    <div class="hbtns">
      <button class="ibtn" onclick="openNotif()" title="通知">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <span class="bdot" id="nbadge"></span>
      </button>
      <button class="ibtn" onclick="togglePv()" title="無痕搜尋">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </button>
    </div>
  </div>

  <div id="pg-search">
    <div class="stitle">搜尋機票</div>
    <div class="scard">
      <div class="ttog">
        <button class="tbtn active" id="btn-rt" onclick="setTrip('round')">來回</button>
        <button class="tbtn" id="btn-ow" onclick="setTrip('one')">單程</button>
        <button class="tbtn" id="btn-mc" onclick="setTrip('multi')">多程</button>
      </div>
      <div class="igrid">
        <div class="arow">
          <div class="igrp">
            <div class="ilbl">出發機場</div>
            <div class="iwrap">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <input class="fi" id="origin" type="text" placeholder="TPE — 台北桃園" list="airports" value="TPE — 台北桃園" />
            </div>
          </div>
          <button class="swpbtn" onclick="swapAirports()">⇄</button>
          <div class="igrp">
            <div class="ilbl">目的機場</div>
            <div class="iwrap">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <input class="fi" id="dest" type="text" placeholder="UKB — 神戶" list="airports" value="UKB — 神戶" />
            </div>
          </div>
        </div>
        <div class="drow">
          <div class="igrp">
            <div class="ilbl">去程日期</div>
            <div class="iwrap">
